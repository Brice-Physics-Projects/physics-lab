# OS / Filesystem Artifacts
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# Project-Specific
# =============================================================================

# Secrets and local configuration — never commit credentials
.env
.env.*
!.env.example
secrets.toml
*.pem
*.key

# Large data files — track provenance in code, not binary blobs
data/raw/
data/interim/
data/processed/
*.h5
*.hdf5
*.parquet
*.feather

# Model checkpoints and weights
models/
*.ckpt
*.pt
*.pth
*.pkl

# Generated outputs / figures (reproducible from notebooks)
outputs/
figures/
reports/generated/

# Logs
logs/
*.log
