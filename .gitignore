# =============================================================================
# Python
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
MANIFEST

# =============================================================================
# Virtual Environments
# =============================================================================

# venv / virtualenv
.venv/
venv/
env/
ENV/

# uv
.uv/
uv.lock

# pip
pip-log.txt
pip-delete-this-directory.txt

# conda
.conda/
conda-meta/
envs/

# poetry
poetry.lock
.poetry/

# =============================================================================
# Package Managers & Tools
# =============================================================================

# pip wheel cache
*.whl

# pyenv
.python-version

# pipenv
Pipfile.lock

# tox
.tox/
.nox/

# =============================================================================
# Jupyter / Notebooks
# =============================================================================

# Notebook checkpoint files (auto-saved intermediates)
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Jupyter runtime files
.jupyter/
profile_default/
ipython_config.py

# nbconvert output (keep .ipynb, ignore generated HTML/PDF/etc.)
*.nbconvert/

# =============================================================================
# Testing & Coverage
# =============================================================================

.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.lcov
nosetests.xml
test-results/

# =============================================================================
# Type Checking & Linting
# =============================================================================

.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# =============================================================================
# IDEs — JetBrains (PyCharm, DataSpell, etc.)
# =============================================================================

.idea/
*.iml
*.iws
*.ipr
out/
# JetBrains shelf / workspace metadata
shelf/
workspace.xml

# =============================================================================
# IDEs — VS Code
# =============================================================================

.vscode/
